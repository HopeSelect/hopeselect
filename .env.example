# Supabase — copie para .env.local e preencha com os valores do painel
# (Project Settings > API). O .env.local é ignorado pelo git.

# Público: pode ir para o browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SEGREDO: nunca exponha no front. Use apenas em rotas de servidor
# (Route Handlers / Server Actions). Não prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
